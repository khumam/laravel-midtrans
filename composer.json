{
    "name": "khumam/laravel-midtrans",
    "description": "Laravel Midtrans payment gateway integration package",
    "keywords": ["laravel", "midtrans", "payment", "gateway"],
    "type": "library",
    "license": "MIT",
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/routing": "^11.0|^12.0|^13.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "Khumam\\Midtrans\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Khumam\\Midtrans\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Khumam\\Midtrans\\MidtransServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
